# Configure these in a .env file or set as environment variables

# ── Azure DevOps (for fetching test cases & creating bugs) ──
AZURE_DEVOPS_ORG=your-organization
AZURE_DEVOPS_PROJECT=your-project
AZURE_DEVOPS_PAT=your-personal-access-token

# ── Google Gemini AI (for AI-enhanced summaries) ──
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# ── Report Settings ──
REPORT_FRAMEWORK=mochawesome
REPORT_INPUT_DIR=./input
REPORT_OUTPUT_DIR=./output/reports
BUG_OUTPUT_DIR=./output/bugs

# ── Bug Ticket Target: "file", "azure", or "jira" ──
BUG_TARGET=file

# ── JIRA (optional, for auto-creating JIRA bugs) ──
# JIRA_URL=https://your-org.atlassian.net
# JIRA_EMAIL=your-email@company.com
# JIRA_TOKEN=your-jira-api-token
# JIRA_PROJECT_KEY=QA

# ── Custom bug template from your manual QA team ──
# BUG_TEMPLATE_PATH=./templates/bug_template.md

# ── Labels ──
TEST_ENVIRONMENT=QA
PROJECT_NAME=Unified-Test-Automation
